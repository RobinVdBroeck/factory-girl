{
  "name": "factory-girl",
  "description": "A factory library for Node.js and JavaScript inspired by factory_girl",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "author": [
    "@aexmachina",
    "@chetanism",
    "Robin Van den Broeck <robin.broeck@gmail.com> (https://github.com/robinvdbroeck)"
  ],
  "version": "5.0.3",
  "keywords": [
    "factory",
    "test",
    "bdd",
    "tdd",
    "fixture"
  ],
  "repository": {
    "type": "git",
    "url": "http://github.com/aexmachina/factory-girl.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "http://github.com/aexmachina/factory-girl/issues"
  },
  "licenses": [
    {
      "type": "MIT",
      "url": "http://github.com/aexmachina/factory-girl/raw/master/LICENSE"
    }
  ],
  "engines": {
    "node": ">=18.12.0"
  },
  "dependencies": {
    "chance": "^1.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "chai": "^5.1.0",
    "chai-as-promised": "^8.0.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-mocha": "^10.5.0",
    "mocha": "^11.0.0",
    "prettier": "^3.4.2",
    "rollup": "^4.29.1",
    "rollup-plugin-delete": "^2.1.0",
    "sinon": "^19.0.2",
    "sinon-chai": "^4.0.0"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src test",
    "test": "NODE_ENV=test mocha",
    "build": "rollup -c ./rollup.config.mjs"
  }
}
