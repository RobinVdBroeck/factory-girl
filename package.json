{
  "name": "@robinvdbroeck/factory-girl",
  "version": "5.0.4",
  "description": "A factory library for Node.js and JavaScript inspired by factory_girl",
  "keywords": [
    "bdd",
    "factory",
    "fixture",
    "tdd",
    "test"
  ],
  "bugs": {
    "url": "http://github.com/robinvdbroeck/factory-girl/issues"
  },
  "license": "MIT",
  "author": [
    "@aexmachina",
    "@chetanism",
    "@robinvdbroeck"
  ],
  "repository": {
    "type": "git",
    "url": "http://github.com/robinvdbroeck/factory-girl.git"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": "./dist/index.js",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint src test",
    "test": "NODE_ENV=test mocha",
    "build": "tsdown",
    "release": "npm run build && changeset publish",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chance": "^1.0.4"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/chai": "^5.2.3",
    "@types/chai-as-promised": "^8.0.2",
    "@types/chance": "^1.1.7",
    "@types/sinon-chai": "^4.0.0",
    "chai": "^6.2.2",
    "chai-as-promised": "^8.0.2",
    "mocha": "^11.7.5",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "sinon": "^21.0.2",
    "sinon-chai": "^4.0.1",
    "tsdown": "^0.21.0",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=22.12"
  },
  "licenses": [
    {
      "type": "MIT",
      "url": "http://github.com/aexmachina/factory-girl/raw/master/LICENSE"
    },
    {
      "type": "MIT",
      "url": "http://github.com/robinvdbroeck/factory-girl/raw/master/LICENSE"
    }
  ]
}
